---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

// JSON-LD untuk SEO Local & Organization
const schemaMarkup = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "Geotextile Barokah Abadi",
	url: "https://geotex.barokahabadi.web.id",
	contactPoint: {
		"@type": "ContactPoint",
		telephone: "+62-888-1211-529",
		contactType: "sales",
		areaServed: "ID",
		availableLanguage: "Indonesian",
	},
	description:
		"Distributor Utama Geotextile Woven, Non Woven, Geomembrane, Geogrid, dan Geobag terbesar di Indonesia. Harga pabrik standar SNI.",
};

// Coba mengambil beberapa produk terbaru/unggulan dari Markdown untuk ditampilkan di HomePage
const semuaProduk = await getCollection("produk");
// Ambil 3 produk teratas saja untuk Highlight di Beranda
const highlightProducts = semuaProduk.slice(0, 3);
---

<Layout
	title="Material dan Solusi Geosintetik Indonesia | Geotextile Barokah Abadi"
	description="Pusat distributor material geosintetik "
	Termurah":
	Geotextile
	Non
	Woven,
	Woven,
	Geomembrane
	HDPE,
	Geogrid
	Biaxial
	standar
	SNI
	siap
	kirim
	dari
	pabrik."
>
	<!-- Menerapkan Schema JSON-LD -->
	<script
		type="application/ld+json"
		set:html={JSON.stringify(schemaMarkup)}
	/>

	<section
		class="hero"
		aria-label="Hero slider showcasing geotextile solutions"
	>
		<div class="hero-slider">
			<!-- Slide 1 – eager load -->
			<div class="slide slide-1">
				<Image
					src="/hero/geotextile-woven-project-national.webp"
					alt="Geotextile woven project national"
					width={1920}
					height={1080}
					loading="eager"
					class="slide-img"
				/>
			</div>

			<!-- Slide 2 – lazy -->
			<div class="slide slide-2">
				<Image
					src="/hero/geomembrane-hdpe.webp"
					alt="Geomembrane HDPE"
					width={1920}
					height={1080}
					loading="lazy"
					class="slide-img"
				/>
			</div>

			<!-- Slide 3 – lazy -->
			<div class="slide slide-3">
				<Image
					src="/hero/geogrid-biaxial.webp"
					alt="Geogrid biaxial"
					width={1920}
					height={1080}
					loading="lazy"
					class="slide-img"
				/>
			</div>

			<!-- Slide 4 – lazy -->
			<div class="slide slide-4">
				<Image
					src="/hero/innovative-construction.webp"
					alt="Innovative construction"
					width={1920}
					height={1080}
					loading="lazy"
					class="slide-img"
				/>
			</div>
		</div>

		<div class="container hero-content">
			<div class="badge">🔥 Agregator Distributor Tangan Pertama🔥</div>
			<h1>
				Distributor <span class="text-accent">Geotextile</span> Tangan Pertama<br
				/>
				Harga Pabrik & SNI 2026
			</h1>
			<p>
				Pusat grosir material geosintetik termurah: Geotextile Woven &
				Non-Woven, Geomembrane HDPE, dan Geogrid. Pilihan utama untuk
				RAB efisien proyek jalan dan konstruksi nasional.
			</p>

			<div class="hero-actions">
				<a
					href="https://wa.me/628881211529?text=Halo%20Geotextile%20Barokah%20Abadi,%20saya%20ingin%20tanya%20harga%20terbaik%20untuk%20proyek%20saya"
					target="_blank"
					class="cta-button primary-cta"
				>
					Dapatkan Penawaran Harga &rarr;
				</a>
				<a href="#katalog-unggulan" class="cta-button secondary-cta"
					>Eksplor Produk</a
				>
			</div>
		</div>
	</section>

	<!-- TRUST FACTORS SECTION -->
	<section class="trust-factors">
		<div class="container">
			<div class="trust-grid">
				<div class="trust-item">
					<div class="icon">🥇</div>
					<h3>Standar SNI & Bina Marga</h3>
					<p>
						Lulus uji tarik (Tensile) & CBR laboratorium untuk
						jaminan kualitas konstruksi.
					</p>
				</div>
				<div class="trust-item">
					<div class="icon">🏭</div>
					<h3>Suplier Tangan Pertama</h3>
					<p>
						Langsung dari pabrik. Harga geotextile per m2 dijamin
						paling kompetitif 2026.
					</p>
				</div>
				<div class="trust-item">
					<div class="icon">🚚</div>
					<h3>Jangkauan Nasional</h3>
					<p>
						Siap kirim dari Aceh hingga Papua, termasuk proyek
						strategis IKN & Trans Sumatra.
					</p>
				</div>
				<div class="trust-item">
					<div class="icon">🤝</div>
					<h3>Konsultasi Teknis</h3>
					<p>
						Gratis perhitungan volume dan spesifikasi material
						sesuai kebutuhan lapangan.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- HIGHLIGHT PRODUK DINAMIS (KGR) -->
	<section class="highlight-products" id="katalog-unggulan">
		<div class="container">
			<h2 class="section-title">Katalog Produk Unggulan</h2>
			<p class="section-subtitle">
				Material geosintetik berkualitas tinggi untuk kebutuhan
				konstruksi Anda.
			</p>

			<div class="grid">
				{
					highlightProducts.map((produk: any) => (
						<article class="product-card">
							<div class="card-image-wrapper">
								{produk.data.image && (
									<Image
										src={produk.data.image}
										alt={produk.data.title}
										width={400}
										height={250}
										format="webp"
										class="card-image"
									/>
								)}
							</div>
							<div class="card-content">
								<h3>{produk.data.title}</h3>
								<p>{produk.data.description}</p>
								<a
									href={`/produk/${produk.id}`}
									class="link-more"
								>
									Spek Lengkap & Detail &rarr;
								</a>
							</div>
						</article>
					))
				}
			</div>

			<div style="text-align: center; margin-top: 60px;">
				<a href="/produk" class="cta-button primary-cta"
					>Lihat Semua Produk &rarr;</a
				>
			</div>
		</div>
	</section>

	<!-- PRICE & SPEC ESTIMATION (FOR SEO/AI SEARCH) -->
	<section class="price-estimation">
		<div class="container">
			<h2 class="section-title">Estimasi Harga Geotextile 2026</h2>
			<p class="section-subtitle">
				Daftar harga referensi per m2 untuk kebutuhan estimasi RAB
				proyek Anda.
			</p>

			<div class="table-responsive">
				<table class="seo-table">
					<thead>
						<tr>
							<th>Jenis Material</th>
							<th>Spesifikasi (GSM)</th>
							<th>Estimasi Harga per m2*</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>Geotextile Non Woven</td>
							<td>150 GSM - 250 GSM</td>
							<td>Rp 11.000 - Rp 25.000</td>
						</tr>
						<tr>
							<td>Geotextile Woven</td>
							<td>150 GSM - 250 GSM</td>
							<td>Rp 10.000 - Rp 28.000</td>
						</tr>
						<tr>
							<td>Geomembrane HDPE</td>
							<td>0.50 mm - 1.00 mm</td>
							<td>Rp 15.000 - Rp 45.000</td>
						</tr>
						<tr>
							<td>Geogrid Biaxial</td>
							<td>20kN - 40kN</td>
							<td>Hubungi Sales</td>
						</tr>
					</tbody>
				</table>
			</div>
			<p class="price-note">
				*Harga dapat berubah sewaktu-waktu tergantung volume pemesanan
				dan lokasi proyek (Loco Pabrik).
			</p>
		</div>
	</section>

	<!-- NATIONAL REACH SECTION -->
	<section class="national-reach">
		<div class="container">
			<div class="reach-flex">
				<div class="reach-text">
					<h2>
						Siap Kirim ke <span class="text-accent"
							>Seluruh Indonesia</span
						>
					</h2>
					<p>
						Geotextile Barokah Abadi memiliki jaringan distribusi
						luas untuk mensuplai proyek infrastruktur strategis
						nasional di berbagai titik:
					</p>
					<ul class="location-list">
						<li>
							<strong>Proyek IKN:</strong> Balikpapan, Penajam Paser
							Utara, Samarinda.
						</li>
						<li>
							<strong>Trans Sumatera:</strong> Lampung, Palembang, Medan,
							Pekanbaru.
						</li>
						<li>
							<strong>Jawa & Bali:</strong> Jakarta, Tangerang, Bandung,
							Semarang, Surabaya, Denpasar.
						</li>
						<li>
							<strong>Sulawesi & Timur:</strong> Makassar, Manado, hingga
							Jayapura.
						</li>
					</ul>
				</div>
				<div class="reach-stats">
					<div class="stat-card">
						<div class="stat-num">500+</div>
						<div class="stat-label">Proyek Selesai</div>
					</div>
					<div class="stat-card">
						<div class="stat-num">24/7</div>
						<div class="stat-label">Dukungan Teknis</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ SECTION FOR GOOGLE AI / SGE -->
	<section class="faq-section">
		<div class="container">
			<h2 class="section-title">Pertanyaan Umum (FAQ)</h2>
			<p class="section-subtitle">
				Jawaban cepat untuk pertanyaan teknis seputar material
				geosintetik.
			</p>

			<div class="faq-grid">
				<div class="faq-item">
					<h3>Apa itu Geotextile dan fungsinya?</h3>
					<p>
						Geotextile adalah lembaran sintetik permeabel yang
						digunakan dalam konstruksi tanah. Fungsinya meliputi
						separasi (mencegah pencampuran tanah), filtrasi,
						drainase, dan perkuatan struktur tanah pada jalan atau
						lereng.
					</p>
				</div>
				<div class="faq-item">
					<h3>Berapa harga Geotextile per m2?</h3>
					<p>
						Harga geotextile bervariasi tergantung pada tipe
						(Woven/Non-Woven) dan gramasi (berat per m2). Sebagai
						distributor tangan pertama, kami menawarkan harga
						kompetitif mulai dari ribuan rupiah per meter persegi
						untuk pembelian grosir/proyek.
					</p>
				</div>
				<div class="faq-item">
					<h3>
						Apakah produk Geotextile Barokah Abadi memiliki
						sertifikat SNI?
					</h3>
					<p>
						Ya, seluruh produk geosintetik kami, termasuk Geotextile
						dan Geomembrane, diproduksi sesuai standar SNI dan
						standar internasional (ISO) untuk menjamin keamanan dan
						daya tahan proyek infrastruktur.
					</p>
				</div>
				<div class="faq-item">
					<h3>Bagaimana cara pemesanan dan pengiriman?</h3>
					<p>
						Anda dapat menghubungi tim sales kami via WhatsApp untuk
						mendapatkan penawaran resmi. Kami melayani pengiriman ke
						seluruh wilayah Indonesia menggunakan armada logistik
						tercepat dan terpercaya.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Apa itu Geotextile dan fungsinya?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Geotextile adalah lembaran sintetik permeabel yang digunakan dalam konstruksi tanah. Fungsinya meliputi separasi, filtrasi, drainase, dan perkuatan struktur tanah."
					}
				},
				{
					"@type": "Question",
					"name": "Berapa harga Geotextile per m2?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Harga geotextile bervariasi tergantung tipe dan gramasi. Sebagai distributor tangan pertama, kami menawarkan harga pabrik kompetitif untuk kebutuhan proyek besar."
					}
				},
				{
					"@type": "Question",
					"name": "Apakah produk Geotextile Barokah Abadi memiliki sertifikat SNI?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Ya, seluruh produk kami telah lulus uji laboratorium dan memenuhi standar SNI serta ISO untuk kualitas material konstruksi nasional."
					}
				},
				{
					"@type": "Question",
					"name": "Bagaimana cara pemesanan dan pengiriman?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Pemesanan dilakukan melalui WhatsApp sales kami. Kami melayani pengiriman ke seluruh pelosok Indonesia mulai dari Sumatera, Kalimantan, hingga Papua."
					}
				}
			]
		}
	</script>
</Layout>

<style>
	/* FAQ Styling */
	.faq-section {
		padding: 100px 0;
		background: var(--white);
	}
	.faq-grid {
		max-width: 900px;
		margin: 0 auto;
		display: grid;
		gap: 30px;
	}
	.faq-item {
		padding: 30px;
		border-radius: 20px;
		background: #f8fafc;
		border-left: 5px solid var(--primary);
		transition: transform 0.3s;
	}
	.faq-item:hover {
		transform: translateX(10px);
		background: #f1f5f9;
	}
	.faq-item h3 {
		color: var(--primary);
		font-size: 1.25rem;
		margin-bottom: 12px;
	}
	.faq-item p {
		color: var(--text-muted);
		line-height: 1.7;
	}

	/* Price Estimation Table */
	.price-estimation {
		padding: 100px 0;
		background: #fff;
	}
	.table-responsive {
		overflow-x: auto;
		margin-top: 40px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
	}
	.seo-table {
		width: 100%;
		border-collapse: collapse;
		background: white;
		min-width: 600px;
	}
	.seo-table th {
		background: var(--primary);
		color: white;
		text-align: left;
		padding: 20px;
		font-family: "Outfit", sans-serif;
	}
	.seo-table td {
		padding: 20px;
		border-bottom: 1px solid #f1f5f9;
		color: var(--text-main);
		font-weight: 500;
	}
	.seo-table tr:last-child td {
		border-bottom: none;
	}
	.seo-table tr:nth-child(even) {
		background: #f8fafc;
	}
	.price-note {
		margin-top: 20px;
		font-size: 0.9rem;
		color: var(--text-muted);
		font-style: italic;
		text-align: center;
	}

	/* Styling Hero dengan Slider Gambar */
	.hero {
		position: relative;
		min-height: 90vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: var(--white);
		overflow: hidden;
	}
	.hero-slider {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -2;
	}
	.slide {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		opacity: 0;
		animation: zoomAndFade4 40s infinite linear;
		filter: brightness(0.5);
	}

	.slide-img {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.slide-1 {
		background-image: url("/hero/geotextile-woven-project-national.webp");
		animation-delay: 0s;
	}
	.slide-2 {
		background-image: url("/hero/geomembrane-hdpe.webp");
		animation-delay: 10s;
	}
	.slide-3 {
		background-image: url("/hero/geogrid-biaxial.webp");
		animation-delay: 20s;
	}
	.slide-4 {
		background-image: url("/hero/innovative-construction.webp");
		animation-delay: 30s;
	}

	@keyframes zoomAndFade4 {
		0% {
			opacity: 0;
			transform: scale(1);
		}
		2.5% {
			opacity: 1;
		}
		22.5% {
			opacity: 1;
		}
		25% {
			opacity: 0;
			transform: scale(1.1);
		}
		100% {
			opacity: 0;
		}
	}

	.hero::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			135deg,
			rgba(6, 78, 59, 0.4),
			rgba(15, 23, 42, 0.6)
		);
		z-index: -1;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.badge {
		background: var(--secondary);
		color: #000;
		display: inline-block;
		padding: 6px 16px;
		border-radius: 50px;
		font-weight: 700;
		font-size: 0.9rem;
		margin-bottom: 20px;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	.hero-content h1 {
		font-size: 4rem;
		margin-bottom: 25px;
		line-height: 1.1;
		font-weight: 700;
	}
	.text-accent {
		color: var(--secondary);
	}
	.hero-content p {
		font-size: 1.3rem;
		max-width: 800px;
		margin: 0 auto 45px auto;
		opacity: 0.9;
		font-weight: 400;
	}

	.hero-actions {
		display: flex;
		gap: 20px;
		justify-content: center;
		align-items: center;
	}

	.cta-button {
		display: inline-block;
		padding: 20px 40px;
		border-radius: 50px;
		font-weight: 700;
		font-size: 1.1rem;
		text-decoration: none;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}
	.primary-cta {
		background-color: var(--primary);
		color: white;
		box-shadow: 0 10px 20px rgba(6, 78, 59, 0.4);
	}
	.primary-cta:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 30px rgba(6, 78, 59, 0.6);
		background-color: #042f24;
	}
	.secondary-cta {
		background-color: rgba(255, 255, 255, 0.1);
		color: var(--white);
		backdrop-filter: blur(5px);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}
	.secondary-cta:hover {
		background-color: var(--white);
		color: var(--primary);
		transform: translateY(-5px);
	}

	/* Trust Factors */
	.trust-factors {
		padding: 40px 0;
		background: var(--white);
		margin-top: -60px;
		position: relative;
		z-index: 100;
		max-width: 1000px;
		margin-left: auto;
		margin-right: auto;
		border-radius: 100px;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
	}
	.trust-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
		text-align: center;
	}
	.trust-item .icon {
		font-size: 2rem;
		margin-bottom: 5px;
	}
	.trust-item h3 {
		font-size: 1rem;
		color: var(--primary);
		margin-bottom: 5px;
	}
	.trust-item p {
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	/* Highlight Products */
	.highlight-products {
		padding: 120px 0;
	}
	.section-title {
		text-align: center;
		font-size: 2.8rem;
		margin-bottom: 15px;
		color: var(--primary);
		font-weight: 700;
	}
	.section-subtitle {
		text-align: center;
		color: var(--text-muted);
		font-size: 1.15rem;
		margin-bottom: 60px;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 40px;
	}
	.product-card {
		background: var(--white);
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
		transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		border: 1px solid rgba(0, 0, 0, 0.05);
	}
	.product-card:hover {
		transform: translateY(-12px);
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);
	}
	.card-image-wrapper {
		position: relative;
		overflow: hidden;
	}
	.card-image {
		width: 100%;
		height: 250px;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.product-card:hover .card-image {
		transform: scale(1.1);
	}
	.card-content {
		padding: 30px;
	}
	.link-more {
		text-decoration: none;
		color: var(--primary);
		font-weight: 700;
		font-size: 1rem;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		transition: transform 0.3s;
