---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

// SSG Path Mapping
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Fetch recent blog posts for the sidebar
const allBlogs = await getCollection('blog');
const recentBlogs = allBlogs
    .filter(p => p.id !== entry.id)
    .sort((a: any, b: any) => {
        const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
        const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
        return dateB - dateA;
    })
    .slice(0, 5);

// SEO Schema
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": entry.data.image ? (typeof entry.data.image === 'string' ? entry.data.image : entry.data.image.src) : '',
  "datePublished": entry.data.pubDate || new Date().toISOString(),
  "author": {
    "@type": "Person",
    "name": entry.data.author || "Tim Barokah Abadi"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Geotextile Barokah Abadi",
    "logo": {
      "@type": "ImageObject",
      "url": "https://geotextile.barokahabadi.web.id/favicon.svg"
    }
  }
};

const waMessage = encodeURIComponent(`Halo Geotextile Barokah, saya baru saja membaca artikel "${entry.data.title}" dan ingin berkonsultasi lebih lanjut mengenai kebutuhan proyek saya.`);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Beranda</a>
        <span class="sep">/</span>
        <a href="/blog">Blog</a>
        <span class="sep">/</span>
        <span class="curr">{entry.data.title}</span>
      </nav>
    </div>
  </div>

  <section class="blog-detail-section">
    <div class="container container-flex">
      <!-- Main Content -->
      <article class="main-content">
        <header class="blog-header">
            <div class="meta-top">
                <span class="date-tag">{entry.data.pubDate ? new Date(entry.data.pubDate).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) : 'Terbaru'}</span>
                <span class="author-label">Oleh: {entry.data.author || 'Tim Ahli'}</span>
            </div>
            <h1>{entry.data.title}</h1>
        </header>

        {entry.data.image && (
           <div class="featured-image">
              {typeof entry.data.image === 'string' ? (
                <img src={entry.data.image} alt={entry.data.title} class="rounded-img" />
              ) : (
                <Image src={entry.data.image} alt={entry.data.title} width={1200} height={700} format="webp" class="rounded-img" />
              )}
           </div>
        )}

        <div class="prose-content">
            <Content />
        </div>
        
        <div class="blog-share-cta">
            <h3>Konsultasi Gratis via WhatsApp</h3>
            <p>Ada pertanyaan mengenai artikel ini atau butuh spesifikasi material untuk proyek Anda?</p>
            <a href={`https://wa.me/628881211529?text=${waMessage}`} class="btn-wa-big" target="_blank">
                Tanya Tim Ahli Geotextile
            </a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-widget">
            <h3>Artikel Terbaru</h3>
            <div class="blog-recent-list">
                {recentBlogs.map(blog => (
                    <a href={`/blog/${blog.id}`} class="recent-item">
                        <span class="blog-item-title">{blog.data.title}</span>
                        <span class="blog-item-date">{blog.data.pubDate ? new Date(blog.data.pubDate).toLocaleDateString('id-ID', {day: 'numeric', month: 'short'}) : ''}</span>
                    </a>
                ))}
            </div>
            <a href="/blog" class="view-all-link">Lihat Semua Artikel &raquo;</a>
        </div>

        <div class="sidebar-widget banner-widget">
            <div class="banner-content">
                <h3>Harga Pabrik SNI</h3>
                <p>Dapatkan harga Geotextile tangan pertama langsung dari distributor untuk proyek nasional.</p>
                <a href="/produk" class="banner-btn">Lihat Katalog</a>
            </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb-bar {
    background: #f8fafc;
    padding: 15px 0;
    border-bottom: 1px solid #e2e8f0;
  }
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: #64748b;
  }
  .breadcrumbs a {
    text-decoration: none;
    color: var(--primary);
    font-weight: 500;
  }
  .breadcrumbs .sep {
    opacity: 0.5;
  }
  .breadcrumbs .curr {
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-detail-section {
    padding: 60px 0 100px;
  }
  .container-flex {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  /* Main Content Styles */
  .blog-header {
    margin-bottom: 35px;
  }
  .meta-top {
    display: flex;
    gap: 20px;
    margin-bottom: 15px;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .date-tag {
    color: var(--primary);
  }
  .author-label {
    color: #64748b;
  }
  .blog-header h1 {
    font-size: 3.2rem;
    color: #0f172a;
    line-height: 1.25;
    margin: 0;
  }
  
  .featured-image {
    margin-bottom: 50px;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
  }
  .rounded-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Markdown Rendering */
  .prose-content :global(h2) {
    font-size: 2.2rem;
    color: var(--primary);
    margin: 45px 0 25px;
    font-weight: 700;
  }
  .prose-content :global(h3) {
    font-size: 1.6rem;
    color: #1e293b;
    margin: 35px 0 20px;
    font-weight: 700;
  }
  .prose-content :global(p) {
    font-size: 1.2rem;
    line-height: 1.85;
    color: #334155;
    margin-bottom: 25px;
  }
  .prose-content :global(ul), .prose-content :global(ol) {
    margin-bottom: 25px;
    padding-left: 20px;
  }
  .prose-content :global(li) {
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: #334155;
  }

  .blog-share-cta {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 50px;
    border-radius: 32px;
    text-align: center;
    margin-top: 80px;
    border: 1px solid #e2e8f0;
  }
  .blog-share-cta h3 {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 15px;
  }
  .blog-share-cta p {
    color: #64748b;
    margin-bottom: 35px;
    font-size: 1.1rem;
  }
  .btn-wa-big {
    display: inline-flex;
    align-items: center;
    background: #25d366;
    color: white;
    padding: 20px 45px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 1.25rem;
    text-decoration: none;
    transition: all 0.3s;
    box-shadow: 0 10px 25px rgba(37, 211, 102, 0.3);
  }
  .btn-wa-big:hover {
    background: #128c7e;
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(37, 211, 102, 0.4);
  }

  /* Sidebar Styles */
  .sidebar {
    position: sticky;
    top: 100px;
  }
  .sidebar-widget {
    background: #fff;
    padding: 35px;
    border-radius: 24px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    border: 1px solid #f1f5f9;
    margin-bottom: 40px;
  }
  .sidebar-widget h3 {
    font-size: 1.4rem;
    margin-bottom: 25px;
    color: #0f172a;
    position: relative;
    padding-left: 15px;
    border-left: 5px solid var(--primary);
  }
  .blog-recent-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 25px;
  }
  .recent-item {
    text-decoration: none;
    display: block;
    padding: 15px;
    background: #f8fafc;
    border-radius: 12px;
    transition: all 0.3s;
  }
  .recent-item:hover {
    background: var(--primary);
  }
  .blog-item-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .blog-item-date {
    font-size: 0.85rem;
    color: #94a3b8;
  }
  .recent-item:hover .blog-item-title,
  .recent-item:hover .blog-item-date {
    color: white;
  }
  .view-all-link {
    display: block;
    text-align: center;
    font-weight: 800;
    color: var(--primary);
    text-decoration: none;
  }

  .banner-widget {
    background: var(--primary);
    color: white;
    text-align: center;
    border: none;
  }
  .banner-widget h3 {
    color: white;
    border-color: var(--secondary);
    padding: 0;
    border: none;
    font-size: 1.8rem;
    margin-bottom: 15px;
  }
  .banner-widget p {
    opacity: 0.9;
    margin-bottom: 30px;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .banner-btn {
    display: block;
    background: var(--secondary);
    color: #000;
    padding: 15px;
    border-radius: 50px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.3s;
  }
  .banner-btn:hover {
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .container-flex {
        grid-template-columns: 1fr;
    }
    .sidebar {
        position: static;
    }
    .blog-header h1 {
        font-size: 2.5rem;
    }
  }
</style>
