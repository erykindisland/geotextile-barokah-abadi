---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const semuaProduk = await getCollection('produk');
---

<Layout 
	title="Katalog Produk Geosintetik & Geotextile Lengkap | Geotextile Barokah Abadi"
	description="Lihat daftar katalog lengkap material Geosynthetics, Geotextile Woven, Non Woven, Geomembrane standar SNI siap kirim ke proyek seluruh Indonesia."
>
	<!-- Hero Section -->
	<header class="catalog-hero">
		<div class="hero-overlay"></div>
		<div class="container hero-inner">
			<nav class="breadcrumb-nav">
				<a href="/">Beranda</a> / <span>Katalog Produk</span>
			</nav>
			<h1>Katalog <span class="text-accent">Geosintetik</span></h1>
			<p>Pusat solusi material konstruksi kelas dunia. Kami menyediakan berbagai jenis produk geosintetik dengan spesifikasi teknis tinggi untuk proyek infrastruktur, pertambangan, dan lingkungan di seluruh Indonesia.</p>
		</div>
	</header>

	<main class="catalog-section">
		<div class="container">
			<div class="catalog-grid">
				{semuaProduk.map((produk: any) => (
					<article class="cat-product-card">
						<div class="card-img-box">
							{produk.data.image && (
								typeof produk.data.image === 'string' ? (
									<img src={produk.data.image} alt={produk.data.title} class="card-img" />
								) : (
									<Image src={produk.data.image} alt={produk.data.title} width={500} height={300} format="webp" class="card-img" />
								)
							)}
							<div class="card-tag">{produk.data.category || 'Premium'}</div>
						</div>
						<div class="card-body">
							<h3>{produk.data.title}</h3>
							<p>{produk.data.description}</p>
							
							<div class="card-footer">
								<a href={`/produk/${produk.id}`} class="btn-primary-sm">Detail Produk &rarr;</a>
							</div>
						</div>
					</article>
				))}
			</div>

			{semuaProduk.length === 0 && (
				<div class="empty-state">
					<div class="icon">📦</div>
					<h3>Belum ada produk tersedia.</h3>
					<p>Silakan hubungi admin kami untuk informasi katalog manual.</p>
					<a href="https://wa.me/628881211529" class="btn-primary-sm">Hubungi WhatsApp</a>
				</div>
			)}
		</div>
	</main>
</Layout>

<style>
	.catalog-hero {
		position: relative;
		background: #0f172a;
		padding: 100px 0 120px;
		color: white;
		text-align: center;
		overflow: hidden;
	}
	.hero-overlay {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		background: radial-gradient(circle at center, rgba(6, 78, 59, 0.4) 0%, transparent 70%);
		z-index: 1;
	}
	.hero-inner {
		position: relative;
		z-index: 10;
		max-width: 900px;
	}
	.breadcrumb-nav {
		font-size: 0.9rem;
		margin-bottom: 20px;
		opacity: 0.7;
		letter-spacing: 1px;
		text-transform: uppercase;
	}
	.breadcrumb-nav a {
		color: white;
		text-decoration: none;
	}
	.catalog-hero h1 {
		font-size: 3.5rem;
		font-weight: 800;
		margin-bottom: 20px;
		line-height: 1.1;
	}
	.text-accent {
		color: var(--secondary);
	}
	.catalog-hero p {
		font-size: 1.25rem;
		opacity: 0.9;
		line-height: 1.6;
	}

	.catalog-section {
		padding: 100px 0;
		background: #f8fafc;
	}
	.catalog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
		gap: 40px;
	}

	.cat-product-card {
		background: white;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 10px 40px rgba(0,0,0,0.03);
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		border: 1px solid #f1f5f9;
		display: flex;
		flex-direction: column;
	}
	.cat-product-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 30px 60px rgba(0,0,0,0.08);
	}

	.card-img-box {
		position: relative;
		height: 240px;
		overflow: hidden;
	}
	.card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.cat-product-card:hover .card-img {
		transform: scale(1.1);
	}
	.card-tag {
		position: absolute;
		top: 20px;
		right: 20px;
		background: var(--secondary);
		color: #000;
		padding: 5px 15px;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 800;
		box-shadow: 0 4px 10px rgba(0,0,0,0.1);
	}

	.card-body {
		padding: 30px;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}
	.card-body h3 {
		font-size: 1.6rem;
		color: #0f172a;
		margin-bottom: 15px;
		font-weight: 700;
	}
	.card-body p {
		color: #64748b;
		line-height: 1.6;
		margin-bottom: 25px;
		flex-grow: 1;
	}

	.btn-primary-sm {
		display: inline-block;
		background: var(--primary);
		color: white;
		padding: 12px 25px;
		border-radius: 50px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.3s;
		font-size: 0.95rem;
	}
	.btn-primary-sm:hover {
		background: #042f24;
		transform: translateX(5px);
	}

	.empty-state {
		text-align: center;
		padding: 100px 0;
	}
	.empty-state .icon {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	@media (max-width: 640px) {
		.catalog-hero h1 {
			font-size: 2.5rem;
		}
		.catalog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
