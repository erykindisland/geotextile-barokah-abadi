---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Hubungi Kami | Distributor Geosintetik Geotextile Barokah Abadi"
	description="Hubungi Geotextile Barokah Abadi untuk konsultasi spesifikasi teknis dan penawaran harga grosir material geotextile, geomembrane, dan bronjong murah."
>
	<header class="contact-hero">
		<div class="container hero-inner">
			<h1>Hubungi <span class="text-accent">Geotextile Barokah Abadi</span></h1>
			<p>Konsultasikan kebutuhan material proyek Anda dengan Sales Engineer kami.</p>
		</div>
	</header>

	<main class="contact-section">
		<div class="container">
			<div class="contact-grid">
				<!-- Form Section -->
				<section class="contact-form-box">
					<h2>Kirim Pesan</h2>
					<p>Isi formulir di bawah ini, tim kami akan menghubungi Anda dalam waktu maksimal 1x24 jam.</p>
					
					<form class="contact-form">
						<div class="form-group">
							<label for="name">Nama Lengkap</label>
							<input type="text" id="name" name="name" placeholder="Contoh: Budi Santoso" required />
						</div>
						<div class="form-group">
							<label for="email">Email Kerja</label>
							<input type="email" id="email" name="email" placeholder="budi@perusahaan.com" required />
						</div>
						<div class="form-group">
							<label for="whatsapp">Nomor WhatsApp</label>
							<input type="tel" id="whatsapp" name="whatsapp" placeholder="0812xxxx" required />
						</div>
						<div class="form-group">
							<label for="subject">Kebutuhan Material</label>
							<select id="subject" name="subject">
								<option value="geotextile">Geotextile Woven / Non Woven</option>
								<option value="geomembrane">Geomembrane HDPE</option>
								<option value="bronjong">Kawat Bronjong</option>
								<option value="produk-lain">Produk Lainnya</option>
							</select>
						</div>
						<div class="form-group">
							<label for="message">Pesan / Lokasi Proyek</label>
							<textarea id="message" name="message" rows="5" placeholder="Sebutkan volume material dan lokasi pengiriman..." required></textarea>
						</div>
						<button type="submit" class="btn-submit">Kirim Penawaran</button>
					</form>
				</section>

				<!-- Info Section -->
				<aside class="contact-info">
					<div class="info-card">
						<h3>Kantor Pemasaran</h3>
						<p>📍 Kavling DPR, Tangerang, Banten 15124, Indonesia</p>
					</div>
					<div class="info-card">
						<h3>Kontak Personal</h3>
						<p>📞 <strong>Telepon:</strong> +62 888 1211 529</p>
						<p>💬 <strong>WhatsApp:</strong> +62 888 1211 529</p>
						<p>✉️ <strong>Email:</strong> info@Geotextile Barokah Abadiabadi.web.id</p>
					</div>
					<div class="info-card">
						<h3>Jam Operasional</h3>
						<p>📅 Senin - Sabtu: 08:00 - 17:00</p>
						<p>📅 Minggu: Tutup (Hanya Layanan WA)</p>
					</div>
					
					<div class="map-placeholder">
						<div class="map-inner">
							<span>Peta Lokasi Tangerang</span>
						</div>
					</div>
				</aside>
			</div>
		</div>
	</main>
</Layout>

<style>
	.contact-hero {
		background: #0f172a;
		padding: 80px 0 100px;
		color: white;
		text-align: center;
	}
	.contact-hero h1 {
		font-size: 3.5rem;
		margin-bottom: 15px;
	}
	.text-accent {
		color: var(--secondary);
	}
	.contact-hero p {
		font-size: 1.25rem;
		opacity: 0.8;
	}

	.contact-section {
		padding: 100px 0;
		background: #f8fafc;
	}
	.contact-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 60px;
	}

	.contact-form-box {
		background: white;
		padding: 50px;
		border-radius: 30px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.05);
	}
	.contact-form-box h2 {
		font-size: 2rem;
		margin-bottom: 10px;
		color: var(--primary);
	}
	.contact-form-box p {
		color: var(--text-muted);
		margin-bottom: 40px;
	}

	.form-group {
		margin-bottom: 25px;
	}
	.form-group label {
		display: block;
		margin-bottom: 8px;
		font-weight: 600;
		color: #334155;
	}
	.form-group input, 
	.form-group select, 
	.form-group textarea {
		width: 100%;
		padding: 15px 20px;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		font-family: inherit;
		font-size: 1rem;
		transition: all 0.3s;
	}
	.form-group input:focus, 
	.form-group select:focus, 
	.form-group textarea:focus {
		outline: none;
		border-color: var(--primary-light);
		box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
	}

	.btn-submit {
		width: 100%;
		background: var(--primary);
		color: white;
		padding: 18px;
		border: none;
		border-radius: 12px;
		font-weight: 700;
		font-size: 1.1rem;
		cursor: pointer;
		transition: all 0.3s;
	}
	.btn-submit:hover {
		background: #042f24;
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(6, 78, 59, 0.2);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 30px;
	}
	.info-card {
		background: white;
		padding: 30px;
		border-radius: 20px;
		border: 1px solid #e2e8f0;
	}
	.info-card h3 {
		color: var(--primary);
		margin-bottom: 15px;
		font-size: 1.25rem;
	}
	.info-card p {
		color: #64748b;
		margin-bottom: 8px;
		line-height: 1.6;
	}

	.map-placeholder {
		height: 250px;
		background: #e2e8f0;
		border-radius: 20px;
		overflow: hidden;
		position: relative;
	}
	.map-inner {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #94a3b8;
		font-weight: 600;
	}

	@media (max-width: 992px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
		.contact-form-box {
			padding: 30px;
		}
	}
</style>
